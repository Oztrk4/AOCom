{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AOCom",
  "version": "0.1.0",
  "identifier": "com.aocom.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AOCom",
        "width": 450,
        "height": 650,
        "minWidth": 450,
        "minHeight": 650,
        "resizable": false,
        "decorations": false,
        "center": true,
        "backgroundColor": "#1e222a",
        "backgroundThrottling": "disabled"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://raw.githubusercontent.com/Oztrk4/AOCom/main/update.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRDRDQzMzQ3NENFRDg1MQpSV1JSMk01ME5FUE5CRnNwZ0VLU0Z1SUVvaEpNRlBXbHhxbjM3dmhib1BxVFZrZDhOSWFCb1Zobgo="
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper" },
      "nsis": {
        "installMode": "perMachine",
        "startMenuFolder": "AOCom",
        "displayLanguageSelector": false
      }
    }
  }
}
